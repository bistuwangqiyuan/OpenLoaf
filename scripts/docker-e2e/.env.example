# ════════════════════════════════════════════════════════════
# 本地开发者：无需创建 .env！
# 容器启动时会自动从宿主机 ~/.openloaf/ 复制 providers.json 和 auth.json。
# 直接运行 `docker compose run behavior-test` 即可。
# ════════════════════════════════════════════════════════════

# ── CI/CD 模式（无宿主机 ~/.openloaf/ 时使用）──────────────
# 复制此文件为 .env 并填入实际值

# AI 模型（必填）
TEST_PROVIDER_ID=openai          # openai / anthropic / deepseek / qwen
TEST_API_URL=https://api.openai.com/v1
TEST_API_KEY=sk-...
TEST_MODEL_ID=gpt-4o-mini
TEST_MODEL_NAME=GPT-4o Mini

# Promptfoo 评分模型（必填，用于 llm-rubric 断言）
PROMPTFOO_GRADING_API_KEY=...

# SaaS 账户 token（可选）
# 有 token 则自动切换到 cloud 模式；无 token 则使用 local 模型
OPENLOAF_SAAS_ACCESS_TOKEN=
